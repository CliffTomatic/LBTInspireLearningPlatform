{
    "ConnectionStrings": {
        "DefaultConnection": "Data Source=MockServer/MockData/pulse.db"
    },
    "Jwt": {
        "Issuer": "InspireAPI",
        "Audience": "InspireClient",
        "ExpiresInMinutes": 120
    },
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "SessionTracking": {
        "HeartbeatIntervalSeconds": 15,
        "MaxMissedHeartbeatMultiplier": 2,
        "IdleTimeoutSeconds": 300
    }
}

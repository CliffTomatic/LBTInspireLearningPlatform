{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "SessionTracking": {
        "HeartbeatIntervalSeconds": 15,
        "MaxMissedHeartbeatMultiplier": 2,
        "IdleTimeoutSeconds": 300
    }
}
